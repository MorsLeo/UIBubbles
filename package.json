{
	"name": "@hyperplexed/bubbles",
	"version": "0.1.0",
	"description": "Android-style app bubbles for the web — floating, draggable, expandable overlay bubbles",
	"author": "Hyperplexed",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/githyperplexed/bubbles.git"
	},
	"homepage": "https://bubbles.hyperplexed.io",
	"bugs": "https://github.com/githyperplexed/bubbles/issues",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite",
		"build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"build:site": "vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"prepublishOnly": "bun run test && bun run build"
	},
	"keywords": [
		"bubbles",
		"chat-heads",
		"floating",
		"overlay",
		"ui",
		"draggable",
		"widget",
		"vanilla",
		"typescript"
	],
	"license": "MIT",
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"marked": "^18.0.5",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsc-alias": "^1.8.17",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
