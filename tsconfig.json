{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"$src/*": ["./packages/core/src/*"],
			"$playground/*": ["./playground/*"],
			"@hyperplexed/bubbles": ["./packages/core/src/index.ts"],
			"@hyperplexed/bubbles-svelte": ["./packages/svelte/src/lib/index.ts"]
		},
		"types": ["vite/client", "node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["packages/core/src", "packages/svelte/src", "playground", "vite.config.ts"]
}
