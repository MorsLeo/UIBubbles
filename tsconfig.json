{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"$src/*": ["./src/*"],
			"$playground/*": ["./playground/*"]
		},
		"types": ["vite/client", "node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src", "playground", "vite.config.ts"]
}
