{
	"name": "@hyperplexed/bubbles",
	"version": "0.8.2",
	"description": "Android-style app bubbles for the web — floating, draggable, expandable overlay bubbles",
	"author": "Hyperplexed",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/githyperplexed/bubbles.git",
		"directory": "packages/core"
	},
	"homepage": "https://bubbles.hyperplexed.io",
	"bugs": "https://github.com/githyperplexed/bubbles/issues",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src",
		"!src/**/*.test.ts"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"prepublishOnly": "bun run --cwd ../.. check && bun run --cwd ../.. test && bun run build"
	},
	"keywords": [
		"bubbles",
		"chat-heads",
		"floating",
		"overlay",
		"ui",
		"draggable",
		"widget",
		"vanilla",
		"typescript"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"rimraf": "^6.1.3",
		"tsc-alias": "^1.8.17",
		"typescript": "^6.0.3"
	}
}
