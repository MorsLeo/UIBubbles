{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": []
	},
	"tsc-alias": {
		"resolveFullPaths": true
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts"]
}
